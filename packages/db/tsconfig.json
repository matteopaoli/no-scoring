{
    "compilerOptions": {
      "target": "ES2015",
      "lib": ["esnext"],
      "allowJs": true,
      "skipLibCheck": true,
      "baseUrl": ".",
      "strict": true,
      "forceConsistentCasingInFileNames": true,
      "noEmit": true,
      "esModuleInterop": true,
      "module": "esnext",
      "moduleResolution": "node",
      "resolveJsonModule": true,
      "isolatedModules": true,
      "jsx": "preserve",
      "incremental": true,
    },
    "exclude": ["node_modules"]
}